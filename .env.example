# Copia este archivo a .env y rellena los valores reales
# En Railway: configura estas variables directamente en el panel de Variables

# Base de datos MySQL (Railway te da estos valores al crear el servicio MySQL)
DB_HOST=
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=MelodiaInstrumental
DB_SSL=false   # Cambia a true si Railway lo requiere

# JWT — genera una clave segura con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# URL del frontend en producción (ej: https://tu-proyecto.vercel.app)
# Railway la usa para el header CORS
FRONTEND_URL=

# ⚠️ NO definir PORT aquí — Railway lo inyecta automáticamente
